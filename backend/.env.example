# AI MOM Assistant - Backend Environment Variables Template

# 🌍 Environment
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-super-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 💾 Database
DATABASE_URL=sqlite+aiosqlite:///./mom_assistant.db

# 🤖 OpenAI
# Get your API key from https://platform.openai.com/
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# 🎙 AssemblyAI (Cloud STT)
# Get your API key from https://www.assemblyai.com/
ASSEMBLY_AI_API_KEY=your-assemblyai-api-key

# 📧 SMTP Email (Gmail recommended)
# Use App Passwords for Gmail: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@botivate.in
SMTP_PASSWORD=your-16-char-app-password
EMAIL_FROM=your-email@botivate.in

# 📱 WhatsApp (Twilio) - Optional
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# 📁 File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# 🌐 Frontend
FRONTEND_URL=http://localhost:5173

# ✨ Branding & White-Labeling
CLIENT_NAME="Your Company Name"
CLIENT_ADDRESS="Your Full Office Address Here"
CLIENT_CS_EMAIL="cs-recipient@yourcompany.com"
SHOW_BOTIVATE_BRANDING=true
BOTIVATE_SIGNATURE="Powered by Botivate Services LLP"

# ☁ Google Cloud Configuration (Sheets & Drive)
# spreadsheet_id is the string in the URL of your Google Sheet
# drive_folder_id is the string in the URL of your Google Drive folder
SPREADSHEET_ID="your-google-spreadsheet-id"
DRIVE_FOLDER_ID="your-google-drive-parent-folder-id"
